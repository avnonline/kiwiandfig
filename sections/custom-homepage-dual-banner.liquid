<div class="custom-dual-banner-wrapper">
  <div class="custom-dual-column">
    <a href="{{ section.settings.link_1 }}" class="custom-dual-link">
      <div class="custom-dual-image">
        {% if section.settings.image_1 %}
          {{ section.settings.image_1 | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      <div class="custom-dual-text-content">
        <h2 class="product__title">{{ section.settings.title_1 }}</h2>
        
        {% if section.settings.subtitle_1 != blank %}
          <p class="custom-dual-subtitle">{{ section.settings.subtitle_1 }}</p>
        {% endif %}
        
        {% if section.settings.button_label_1 != blank %}
          <span class="custom-dual-btn">{{ section.settings.button_label_1 }}</span>
        {% endif %}
      </div>
    </a>
  </div>
  
  <div class="custom-dual-column">
    <a href="{{ section.settings.link_2 }}" class="custom-dual-link">
      <div class="custom-dual-image">
        {% if section.settings.image_2 %}
          {{ section.settings.image_2 | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'collection-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      <div class="custom-dual-text-content">
        <h2 class="product__title">{{ section.settings.title_2 }}</h2>
        
        {% if section.settings.subtitle_2 != blank %}
          <p class="custom-dual-subtitle">{{ section.settings.subtitle_2 }}</p>
        {% endif %}
        
        {% if section.settings.button_label_2 != blank %}
          <span class="custom-dual-btn">{{ section.settings.button_label_2 }}</span>
        {% endif %}
      </div>
    </a>
  </div>
</div>

<style>
  /* Base Layout */
  .custom-dual-banner-wrapper {
    display: flex;
    gap: 1.5rem;
    padding: 0;
    max-width: 100%;
    margin: 0;
  }
  
  .custom-dual-column {
    flex: 1;
    position: relative;
    overflow: hidden;
  }
  
  .custom-dual-link {
    display: block;
    position: relative;
    text-decoration: none;
    height: 100%;
  }
  
  /* Image Setup */
  .custom-dual-image {
    position: relative;
    width: 100%;
    height: 100%;
    aspect-ratio: 4/5; 
  }
  
  .custom-dual-image img,
  .custom-dual-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease;
  }
  
  /* Hover Zoom */
  .custom-dual-link:hover .custom-dual-image img {
    transform: scale(1.05);
  }
  
  /* Overlay Gradient for Text Readability */
  .custom-dual-image::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
    pointer-events: none;
  }
  
  /* Text and Button Positioning */
  .custom-dual-text-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start; 
    justify-content: flex-end;
    z-index: 2;
    padding: 5rem; 
  }

  /* Title Style */
  .custom-dual-text-content .product__title {
    color: #ffffff !important;
    margin: 0 0 0.8rem 0 !important; /* Tighter gap below title */
    text-align: left;
    line-height: 1.1;
  }

  /* Subtitle Style */
  .custom-dual-subtitle {
    color: #ffffff;
    font-size: 1.1rem; 
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 2rem 0 !important; /* Measured gap before button */
    font-weight: 500;
  }
  
  /* TRANSLUCENT BUTTON STYLE */
  .custom-dual-btn {
    display: inline-block;
    background: rgba(255, 255, 255, 0.18) !important; /* Exact match from your CSS */
    color: #ffffff !important;
    border: 1px solid #ffffff !important;
    min-width: 15rem;
    padding: 1.2rem 3rem;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    font-size: 1.3rem;
  }
  
  /* Solid hover state (inverts the button) */
  .custom-dual-link:hover .custom-dual-btn {
    background: #ffffff !important;
    color: #111111 !important;
  }
  
  /* Mobile Adjustments */
  @media screen and (max-width: 749px) {
    .custom-dual-banner-wrapper {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .custom-dual-text-content {
      padding: 3rem 2rem; 
    }
    
    .custom-dual-text-content .product__title {
      font-size: 2.2rem !important;
    }
    
    .custom-dual-btn {
      min-width: 12rem;
      padding: 1rem 2rem;
      font-size: 1.2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Side-by-Side Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Left Image" },
    { "type": "text", "id": "title_1", "label": "Left Heading", "default": "WOMEN'S" },
    { "type": "text", "id": "subtitle_1", "label": "Left Subtitle", "default": "EXPLORE THE LATEST" },
    { "type": "text", "id": "button_label_1", "label": "Left Button Label", "default": "SHOP NOW" },
    { "type": "url", "id": "link_1", "label": "Left Link" },
    
    { "type": "image_picker", "id": "image_2", "label": "Right Image" },
    { "type": "text", "id": "title_2", "label": "Right Heading", "default": "MEN'S" },
    { "type": "text", "id": "subtitle_2", "label": "Right Subtitle", "default": "EXPLORE THE LATEST" },
    { "type": "text", "id": "button_label_2", "label": "Right Button Label", "default": "SHOP NOW" },
    { "type": "url", "id": "link_2", "label": "Right Link" }
  ],
  "presets": [
    {
      "name": "Side-by-Side Banner"
    }
  ]
}
{% endschema %}